dimensions      [];

internalField   uniform 160.99;

boundaryField
{
    lowerWall
    {
        type            zeroGradient;
    }
    lowerSymmetry
    {
        type            zeroGradient;
    }
    upperSymmetry
    {
        type            zeroGradient;
    }
    inlet
    {
        type            fixedValue;
        value           nonuniform List<scalar> 
0
;
    }
    outlet
    {
        type            zeroGradient;
    }
    defaultFaces
    {
        type            empty;
    }
    procBoundary0to1
    {
        type            processor;
        value           uniform 160.99;
    }
    procBoundary0to2
    {
        type            processor;
        value           uniform 160.99;
    }
}


