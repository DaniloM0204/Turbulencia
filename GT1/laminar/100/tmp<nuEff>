FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "100";
    object      tmp<nuEff>;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0.002;

boundaryField
{
    top
    {
        type            calculated;
        value           uniform 0.002;
    }
    inlet
    {
        type            calculated;
        value           uniform 0.002;
    }
    outlet
    {
        type            calculated;
        value           uniform 0.002;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
}


